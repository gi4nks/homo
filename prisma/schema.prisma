// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Book {
  id                 String          @id @default(uuid())
  title              String
  genre              String          @default("") 
  synopsis           String          @default("")
  genreSpecificGoals String          @default("") 
  characters         String          @default("") 
  tone               String          @default("Professional")
  styleReference     String          @default("")
  authorialIntent    String          @default("")
  loreConstraints    String          @default("")
  status             String          @default("Planning")
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  chapters           Chapter[]
  charactersList     Character[]
  
  // Relation to existing GenreConfig system
  genreConfig        GenreConfig?    @relation(fields: [genreId], references: [id])
  genreId            String?

  // NEW: Dynamic Prompt CMS relations
  defaultPromptTemplateId String?
  defaultPromptTemplate   PromptTemplate? @relation(fields: [defaultPromptTemplateId], references: [id])
  
  defaultAiProfileId      String?
  defaultAiProfile        AiProfile?      @relation(fields: [defaultAiProfileId], references: [id])

  targetWordCount    Int?            @default(80000)
}

model Character {
  id          String   @id @default(uuid())
  book        Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  bookId      String
  name        String
  role        String   @default("")
  description String   @default("")
  scenes      Scene[]  @relation("SceneCast")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Chapter {
  id            String   @id @default(uuid())
  book          Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  bookId        String
  title         String
  orderIndex    Int
  chapterNumber Int      @default(1)
  chapterGoal   String   @default("")
  scenes        Scene[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([bookId])
}

model Scene {
  id          String      @id @default(uuid())
  chapter     Chapter     @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  chapterId   String
  title       String
  content     String      @default("")
  promptGoals String      @default("")
  narrativePosition String @default("Metà")
  orderIndex  Int
  sceneNumber Int         @default(1)
  wordCount   Int         @default(0)
  isLocked    Boolean     @default(false)
  characters  Character[] @relation("SceneCast")
  snapshots   Snapshot[]

  // NEW: Scene-level AI Default Configuration
  defaultAiProfileId      String?
  defaultAiProfile        AiProfile?      @relation(fields: [defaultAiProfileId], references: [id])
  defaultPromptTemplateId String?
  defaultPromptTemplate   PromptTemplate? @relation(fields: [defaultPromptTemplateId], references: [id])

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([chapterId])
}

model GenreConfig {
  id                String   @id @default(uuid())
  genreName         String   @unique
  customPromptRules String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  books             Book[]
}

model AiProfile {
  id           String   @id @default(uuid())
  name         String   @unique
  description  String?
  systemPrompt String
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  books        Book[]   // Default for books
  scenes       Scene[]  // NEW: Back-relation for scene defaults
}

model PromptTemplate {
  id                String   @id @default(uuid())
  name              String   @unique
  description       String?
  phase             PipelinePhase @default(DRAFTING)
  systemInstruction String   // [SYSTEM CORE: HOMO ENGINE] ...
  contextTemplate   String   // XML tags with {{interpolation}}
  taskDirective     String   // Specific task logic
  isDefault         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  books             Book[]
  scenes            Scene[]  // NEW: Back-relation for scene defaults
}

enum PipelinePhase {
  WORLDBUILDING
  OUTLINING
  DRAFTING
  EDITING
  UTILITY
}

model AppSettings {
  id               String     @id @default("global")
  activeProvider   AIProvider @default(GOOGLE)
  activeModelName  String     @default("gemini-2.5-flash")
  updatedAt        DateTime   @updatedAt
}

enum AIProvider {
  GOOGLE
  OPENAI
  ANTHROPIC
  CUSTOM
}

model Snapshot {
  id        String   @id @default(uuid())
  scene     Scene    @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  sceneId   String
  content   String
  createdAt DateTime @default(now())
  label     String?
}
